# Copy to .env and fill values from private course materials (never commit .env).

# OpenAI or OpenRouter (see root config.js)
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# AI_PROVIDER=openai

# Hub (base URL only — no trailing slash)
AI_DEVS_HUB_BASE=
AI_DEVS_API_KEY=

# Hub paths (path only, leading /; from private docs — never full URLs). Use {apiKey} where the URL embeds your key.
AI_DEVS_HUB_PATH_VERIFY=
AI_DEVS_HUB_PATH_CATEGORIZE_CSV=
AI_DEVS_HUB_PATH_ELECTRICITY_ASSET=

# electricity — local PNG of target/solved board (from private materials; never commit)
# ELECTRICITY_TARGET_IMAGE=solved_electricity.local.png
AI_DEVS_HUB_PATH_DRONE_MAP=
AI_DEVS_HUB_PATH_API_LOCATION=
AI_DEVS_HUB_PATH_API_ACCESSLEVEL=
AI_DEVS_HUB_PATH_API_PACKAGES=
AI_DEVS_HUB_PATH_API_ZMAIL=

# categorize — hub JSON "code" values from private documentation (required for that solution)
AI_DEVS_HUB_CATEGORIZE_CODE_OK=
AI_DEVS_HUB_CATEGORIZE_CODE_WRONG_CLASS=
AI_DEVS_HUB_CATEGORIZE_CODE_BUDGET=

# --- sendit (declaration fields — from your task / notes)
# SENDIT_INITIAL_INPUT_FILE=/absolute/path/to/sendit-mission.txt
# SENDIT_SENDER_ID=
# SENDIT_ORIGIN=
# SENDIT_DESTINATION=
# SENDIT_ROUTE_CODE=
# SENDIT_CATEGORY=
# SENDIT_WEIGHT_KG=
# SENDIT_ADDITIONAL_WAGONS=
# SENDIT_DESCRIPTION=
# SENDIT_NOTES=brak
# SENDIT_AMOUNT_LABEL=

# --- drone (map analysis + mission — from private materials)
# DRONE_VISION_PROMPT=
# DRONE_AGENT_MISSION=
